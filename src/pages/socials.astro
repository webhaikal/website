---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="sera - socials">
	<div class="hidden" id="home">
		<a href="/" class="flicker pagelabel" style="animation-delay: 0.2s"
			>&lt; back</a
		>

		<div class="flicker" style="animation-delay: 0.4s">
			<h1>socials</h1>
		</div>

		<div class="flicker" style="animation-delay: 0.8s">
			<h2 class="indent">
				<a href="https://github.com/webhaikal">github</a>
			</h2>
			<p class="doubleindent gray">software & programming</p>
		</div>

		<div class="flicker" style="animation-delay: 1.1s">
			<h2 class="indent">
				<a href="https://steamcommunity.com/id/its_serabtw/">steam</a>
			</h2>
			<p class="doubleindent gray">/id/its_serabtw</p>
		</div>

		<div class="flicker" style="animation-delay: 1.2s">
			<h2 class="indent">
				<a href="https://www.discordapp.com/users/321518809624215564"
					>discord</a
				>
			</h2>
			<p class="doubleindent gray">its_sarabtw</p>
		</div>

		<div class="flicker" style="animation-delay: 1.5s">
			<h2 class="indent">
				<a href="https://twitter.com/its_serabtw">twtter</a>
			</h2>
			<p class="doubleindent gray">@it_serabtw</p>
		</div>

		<div class="flicker" style="animation-delay: 1.5s">
			<h2 class="indent">
				<a href="https://t.me/its_serabtw">telegram</a>
			</h2>
			<p class="doubleindent gray">@it_serabtw</p>
		</div>
	</div>

	<script>
		setTimeout(function () {
			document.getElementById("home").classList.remove("hidden");
		}, 1300);

		if (new URL(document.referrer).origin == new URL(document.URL).origin) {
			document.getElementById("main").style.animationDuration = "0s";
			document.getElementById("main").style.animationDelay = "0s";
			document.getElementById("home").classList.remove("hidden");
		}
	</script>
</MainLayout>
